    {
      "id": "xs2p9z3b73r3",
      "name": "Disruption with GitHub's code search",
      "status": "investigating",
      "created_at": "2026-04-01T15:02:54.256Z",
      "updated_at": "2026-04-01T19:37:57.578Z",
      "monitoring_at": null,
      "resolved_at": null,
      "impact": "major",
      "shortlink": "https://stspg.io/1zgx17jdj4k7",
      "started_at": "2026-04-01T15:02:54.247Z",
      "page_id": "kctbh9vrtdwd",
      "incident_updates": [
        {
          "id": "rg9gs05n3rvj",
          "status": "investigating",
          "body": "We are still working on recovering back to a serviceable state and expect to have a more substantial update within another two hours.",
          "incident_id": "xs2p9z3b73r3",
          "created_at": "2026-04-01T19:37:57.575Z",
          "updated_at": "2026-04-01T19:37:57.575Z",
          "display_at": "2026-04-01T19:37:57.575Z",
          "affected_components": null,
          "deliver_notifications": true,
          "custom_tweet": null,
          "tweet_id": null
        },
        {
          "id": "sq7z8g7nfjcm",
          "status": "investigating",
          "body": "We are observing some recovery for Code Search queries, but customers should be aware that the data being served may be stale, especially for changes that took place after 07:00 UTC today (1 April 2026). We are still working on recovering our ingestion pipeline, and synchronizing the indexed data.<br /><br />We will update again within 2 hours.",
          "incident_id": "xs2p9z3b73r3",
          "created_at": "2026-04-01T17:48:15.072Z",
          "updated_at": "2026-04-01T17:48:15.072Z",
          "display_at": "2026-04-01T17:48:15.072Z",
          "affected_components": null,
          "deliver_notifications": true,
          "custom_tweet": null,
          "tweet_id": null
        },
        {
          "id": "cqmtd386yjvc",
          "status": "investigating",
          "body": "We identified an issue in our ingestion pipeline that degraded the freshness of Code Search results. While fixing the issue with the ingestion pipeline, a deployment caused a loss of dynamic configuration which is causing most requests for Code Search results to fail. We are working to restore the service and to re-ingest the misaligned data.",
          "incident_id": "xs2p9z3b73r3",
          "created_at": "2026-04-01T16:00:31.111Z",
          "updated_at": "2026-04-01T16:00:31.111Z",
          "display_at": "2026-04-01T16:00:31.111Z",
          "affected_components": null,
          "deliver_notifications": true,
          "custom_tweet": null,
          "tweet_id": null
        },
        {
