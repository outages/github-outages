        },
        {
          "id": "0qpymhbwnxv0",
          "status": "investigating",
          "body": "We are actively reindexing the remaining ElasticSearch indexes. Our priority is ensuring correctness and avoiding further impact.  We are taking a measured approach to safely backfill data and will share additional updates as progress continues.",
          "incident_id": "x69zbgdyfzg0",
          "created_at": "2026-04-28T15:58:40.533Z",
          "updated_at": "2026-04-28T15:58:40.533Z",
